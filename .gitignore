# =============================================================================
# ROOT .gitignore - secure-web-product
# =============================================================================

# Node & npm
node_modules/
npm-debug.log

# Vite / build artefacts
dist/
.vite/
*.local

# OS / editor artefacts
.DS_Store
Thumbs.db
.idea/
.vscode/

# Environment files (CRITICAL - never commit secrets)
.env
.env.local
.env.*.local

# Test coverage reports
coverage/
*.lcov
.nyc_output

# Package artifacts (avoid committing binaries)
*.tgz
*.tar.gz
*.zip

# Netlify function bundles (source files OK, bundles ignored)
netlify/functions/*.bundle.js
.netlify/

# =============================================================================
# EXCEPTIONS - Keep these tracked
# =============================================================================

# Netlify function source files (not bundles)
!netlify/functions/audit_log.js
!netlify/functions/github-webhook.js

# Documentation source files
!docs/*.md
!docs/**/*.md

# =============================================================================
# DEMO SCRIPTS - Prevent accidental commits
# =============================================================================

# Demo scripts in frontend (if they exist at root)
scripts/*-demo.ts
scripts/*-demo.js
