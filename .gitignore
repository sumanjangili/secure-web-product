# =============================================================================
# ROOT .gitignore - secure-web-product
# =============================================================================

# Node & npm
node_modules/
netlify/functions/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build artifacts & caches
dist/
.vite/
.cache/
*.local
*.tsbuildinfo

# OS / Editor artifacts
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes
.idea/
*.swp
*.swo
*~
.vscode/
!.vscode/extensions.json  # Optional: Allow shared extension recommendations
!.vscode/tasks.json       # Optional: Allow shared tasks

# Environment files (CRITICAL - NEVER commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.log

# Test coverage
coverage/
*.lcov
.nyc_output/

# Package artifacts (binaries & archives)
*.tgz
*.tar.gz
*.zip
*.node
*.so
*.dll

# Netlify specific
.netlify/
netlify/functions/*.bundle.js
netlify/functions/*.zip
# Ignore the build cache directory
.netlify-build/

# =============================================================================
# DOCUMENTATION & SOURCE (KEEP TRACKED)
# =============================================================================

# Ensure all source code is tracked (Default behavior, but explicit for clarity)
# No negation rules needed here unless you have specific folders to ignore.

# =============================================================================
# EXCLUSIONS (What NOT to ignore)
# =============================================================================

# If you have a specific .gitignore in subfolders that ignores too much,
# you can override here, but generally, root ignores are sufficient.

# Ensure package.json and lockfiles are tracked
!package.json
!package-lock.json
!npm-shrinkwrap.json
!yarn.lock
!pnpm-lock.yaml

# Ensure Netlify config is tracked
!netlify.toml
!netlify/

# Ensure docs are tracked
!docs/
!docs/*.md
