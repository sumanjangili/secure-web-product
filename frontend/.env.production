# frontend/.env.production
# Production - Netlify will serve from same domain
VITE_API_URL=/
VITE_AUDIT_LOG_ENDPOINT=/audit_log
VITE_NETLIFY_CONTEXT=production
VITE_ENABLE_EXPERIMENTAL_FEATURES=false
VITE_DEBUG_MODE=false

# Vite exposes variables prefixed with VITE_
# VITE_API_URL=https://securewebproducts-netlify.app
# VITE_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE
# VITE_AUDIT_LOG_ENDPOINT=/.netlify/functions/audit_log
