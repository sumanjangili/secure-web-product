# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES (.env.example)
# =============================================================================
# Copy this file to .env and fill in your values.
# ⚠️  NEVER commit .env to version control. It is in .gitignore.
# =============================================================================

# --- Application Configuration ---
# Base URL for the API (used for fetch requests)
VITE_API_URL=https://securewebproducts-netlify.app

# --- Netlify Serverless Integration ---
# Endpoint for the audit logging function
# Format: /.netlify/functions/<function-name>
VITE_AUDIT_LOG_ENDPOINT=/.netlify/functions/audit_log

# --- Encryption & Security (Optional) ---
# Public key for asymmetric encryption (if using RSA/ECC)
# VITE_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE

# --- Build & Deployment Context ---
# Used to conditionally load configs based on environment
# Values: development, staging, production
VITE_NETLIFY_CONTEXT=development

# --- Feature Flags ---
# Enable/disable experimental features
VITE_ENABLE_EXPERIMENTAL_FEATURES=false

# --- Debugging (Development Only) ---
# Set to 'true' to enable verbose logging (disable in production)
VITE_DEBUG_MODE=false
