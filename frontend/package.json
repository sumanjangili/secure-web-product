{
  "name": "@sumanjangili/secure-web-product",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A privacy-first audit-logging solution with React frontend and Netlify serverless functions.",
  "author": "Suman Jangili",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sumanjangili/secure-web-product.git",
    "directory": "frontend"
  },
  "bugs": {
    "url": "https://github.com/sumanjangili/secure-web-product/issues"
  },
  "homepage": "https://github.com/sumanjangili/secure-web-product",
  "keywords": [
    "vite",
    "react",
    "encryption",
    "audit-logging",
    "privacy"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/generate-csp.cjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "bash ./scripts/clean.sh",
    "gen-docs": "ts-node --esm ./scripts/generate-docs.ts",
    "encrypt-demo": "echo '⚠️  WARNING: Demo script only. Do not run in production.' && ts-node --esm ./scripts/encrypt-demo.ts",
    "audit": "npm audit",
    "prepare": "husky install"
  },
  "dependencies": {
    "otpauth": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^24.12.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitejs/plugin-react": "^4.7.0",
    "baseline-browser-mapping": "^2.9.18",
    "dotenv": "^16.5.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
