# frontend/.gitignore
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules

# Build outputs
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment variables (Critical for security)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Demo scripts (Prevent accidental commits of insecure code)
scripts/*-demo.ts
scripts/*-demo.js

# Package artifacts
*.tgz
*.tar.gz

# Test coverage
coverage
*.lcov
.nyc_output

# Vite specific
*.map
