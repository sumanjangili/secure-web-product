# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string for user data and audit logs
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@localhost:5432/your_database_name

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT Secret - Used to sign and verify JSON Web Tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-very-long-random-hex-string-here

# Audit Secret - Internal header for admin-only function access
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_SECRET=your-admin-secret-here

# ============================================
# REDIS (Upstash) CONFIGURATION
# ============================================
# Rate limiting and session management via Upstash Redis
# Get these from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-very-long-redis-token-here

# ============================================
# WEBHOOK CONFIGURATION (Optional)
# ============================================
# GitHub webhook secret for verifying incoming webhook requests
# Get this from: GitHub Repo Settings > Webhooks
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here

# ============================================
# NETLIFY CONFIGURATION (Auto-injected, no need to set locally)
# ============================================
# These are automatically available in Netlify Functions:
# - CONTEXT (production, deploy-preview, dev)
# - DEPLOY_PRIME_URL
# - SITE_ID
# No need to add these to .env
